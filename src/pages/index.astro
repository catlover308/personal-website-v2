---
import "../styles/global.css";
import cardframe from "../pages/components/cardframe.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Bryce Lee</title>
	</head>
	<body>
		<div class="lander-wrapper">
			<div class="lander-card">
				<div class="lander-name-container">
					<h1 class="tomorrow-semibold">Bryce Lee</h1>
				</div>
				<!-- <div class="lander-subtitle-container">
					<h2 class="tomorrow-regular">
						Aspiring Engineer in Santa Clarita, CA
					</h2>
				</div> -->
			</div>
			<!-- #region buttons -->
			<!-- email -->
			<button class="social-buttons" onclick="copyemail()">
				<svg
					width="48"
					height="48"
					viewBox="0 0 24 24"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M21 4V5H20V6H19V7H18V8H17V9H16V10H15V11H14V12H13V13H11V12H10V11H9V10H8V9H7V8H6V7H5V6H4V5H3V4H21Z"
						fill="currentColor"></path>
					<path
						d="M23 5V19H22V20H2V19H1V5H3V6H4V7H5V8H6V9H7V10H8V11H9V12H10V13H11V14H13V13H14V12H15V11H16V10H17V9H18V8H19V7H20V6H21V5H23Z"
						fill="currentColor"></path>
				</svg>
			</button>
			<!-- github -->
			<button class="social-buttons" onclick="copygithub()">
				<svg> <img src="../assets/github.svg" alt="" /></svg>
			</button>
			<!-- twitter -->
			<button class="social-buttons" onclick="copytwitter()">
				<svg> <img src="../assets/twitter.svg" alt="" /></svg>
			</button>
			<!-- instagram -->
			<button class="social-buttons" onclick="copyinstagram()">
				<svg> <img src="../assets/instagram.svg" alt="" /></svg>
			</button>
			<!-- linkedin -->
			<button class="social-buttons" onclick="copylinkedin()">
				<svg> <img src="../assets/linkedin.svg" alt="" /></svg>
			</button>
			<!-- discord -->
			<button class="social-buttons" onclick="copydiscord()">
				<svg> <img src="../assets/discord.svg" alt="" /></svg>
			</button>
			<!-- #endregion -->
			<!-- #region scrolling text -->
			<svg class="scrolling-path">
				<path
					id="trace"
					d=""
					fill="none"
					stroke="black"
					stroke-width="2"
				>
				</path>
				<scrolltext dy="-10">
					<textpath
						id="scrollingtext"
						href="#trace"
						text-anchor="middle"
					>
						ttesteiojdmsfijlkanmdjaskljdmsjlasmdkjsalm
					</textpath>
				</scrolltext>
			</svg>
			<!-- #endregion -->
		</div>
		<cardframe>
			<div class="project-card"></div>
			<div class="info-card"></div>
			<div class="curated-card"></div>
		</cardframe>
	</body>
	<script>
		// #region hand coded, creates dynamic SVG for scrolling text
		const card = document.querySelector(".lander-card") as HTMLElement;
		function refresh() {
			const rect = card?.getBoundingClientRect();
			const textoffset = 24;
			const cardradius = 48;
			const path = `M ${rect.x + cardradius},${rect.y + textoffset} 
			L${rect.right - cardradius} ${rect.y + textoffset} 
			Q ${rect.right - textoffset} ${rect.y + textoffset} ${rect.right - textoffset} ${rect.y + cardradius} 
			L ${rect.right - textoffset} ${rect.bottom - cardradius} 
			Q ${rect.right - textoffset} ${rect.bottom - textoffset} ${rect.right - cardradius} ${rect.bottom - textoffset} 
			L${rect.left + cardradius} ${rect.bottom - textoffset} 
			Q ${rect.left + textoffset} ${rect.bottom - textoffset} ${rect.left + textoffset} ${rect.bottom - cardradius}
			L ${rect.left + textoffset} ${rect.y + cardradius} 
			Q ${rect.left + textoffset} ${rect.y + textoffset} ${rect.left + cardradius} ${rect.y + textoffset} Z`;
			const svgpath = document.querySelector("#trace") as SVGPathElement;
			svgpath.setAttribute("d", path);
			svgpath.setAttribute("id", "trace");
		}
		// #endregion
		// #region thanks claude
		new ResizeObserver(refresh).observe(card);
		refresh();
		const scrollingtext = document.querySelector(
			"#scrollingtext",
		) as SVGTextPathElement;
		let position = 0;
		function animate() {
			position += 0.1;
			if (position > 100) position = 0;
			scrollingtext.setAttribute(
				"startOffset",
				position.toString() + "%",
			);
			requestAnimationFrame(animate);
		}
		animate();
		// #endregion
	</script>
</html>
